def findAllInfo(date=None):
    try:
        if date == None:
            date = dt.date.today().strftime("%Y%m%d")
            date = CCF.tradingDay[CCF.tradingDay < date][-1]

        cinfo = {}
        etfinfo = {}

        try:
            cinfo = findUnderlyingOptionInfoCommodity(date)
        except Exception as e:
